{
  "name": "trust-sense-desktop",
  "version": "1.0.0",
  "description": "TRUST SENSE - Media Intelligence Desktop Application",
  "main": "main.js",
  "scripts": {
    "css:build": "tailwindcss -i ./src/index.css -o ./src/index.output.css",
    "css:watch": "tailwindcss -i ./src/index.css -o ./src/index.output.css --watch",
    "start": "npm run css:build && electron .",
    "dev": "npm run css:watch & electron .",
    "build": "npm run css:build && electron-builder",
    "pack": "npm run css:build && electron-builder --dir",
    "dist": "npm run css:build && electron-builder"
  },
  "author": "TRUST SENSE Team",
  "license": "MIT",
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "electron": "latest",
    "electron-builder": "latest",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.14"
  },
  "dependencies": {
    "axios": "latest",
    "expo": "^50.0.0",
    "react": "^19.2.0",
    "react-native": "^0.83.4",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.23.0",
    "sqlite3": "latest",
    "uuid": "latest"
  }
}
