{
  "manifest_version": 2,
  "name": "Codexia - Trust Sense",
  "version": "1.0",
  "description": "Analyze content credibility with AI-powered trust scoring",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>",
    "storage"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon-48.png",
    "default_title": "Codexia Trust Sense"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    "popup.html"
  ]
}
