# Trust Sense — Root .env.example (copy to .env and fill for Docker/local)
# For free hosting, set these in Vercel (frontend) and Render (backend) dashboards.

# ========== FRONTEND (Vite — used at build time) ==========
VITE_API_URL=https://your-backend.onrender.com

# ========== SUPABASE (required for authentication) ==========
# Create a project at https://supabase.com/dashboard then:
# Project Settings → API → Project URL and anon public key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ========== BACKEND (used by backend service) ==========
# SECRET_KEY=generate-a-long-random-secret
# CORS_ORIGINS=https://your-app.vercel.app
# ENVIRONMENT=production
# Optional: ANTHROPIC_API_KEY, HUGGINGFACE_API_KEY
# Optional: REDIS_URL (Upstash), DATABASE_URL (PostgreSQL)
