# Trust Sense Backend — copy to .env
# Used when running backend locally or in Docker.

DATABASE_URL=sqlite:///./trust_sense.db
SECRET_KEY=your-secret-key-change-in-production
CORS_ORIGINS=*
ENVIRONMENT=development

# Optional: restrict CORS in production (comma-separated)
# CORS_ORIGINS=https://trust-sense.vercel.app,https://yourapp.vercel.app

# Supabase JWT secret (Project Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=

# AI (optional)
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxx

# Get from: https://console.groq.com/keys (FREE!)
GROQ_API_KEY=gsk_xxxxxxxxxxxxx

# Power BI (optional)
# POWERBI_API_URL=
# POWERBI_DATASET_ID=
# POWERBI_TOKEN=
